<view class="container">
  <view class="user-card card">
    <view class="user-info">
      <image class="user-avatar" src="{{userInfo.avatar_url || '/images/default-avatar.png'}}" mode="aspectFill" bindtap="updateAvatar"/>
      <view class="user-meta">
        <view class="user-name">{{userInfo.nickname || '未设置昵称'}}</view>
        <view class="user-stats">
          <text>点滴 {{momentCount}}</text>
          <text class="divider">|</text>
          <text>在一起 {{loveDays}} 天</text>
        </view>
      </view>
    </view>
    <view class="edit-profile" bindtap="editProfile">编辑资料 ›</view>
  </view>

  <view class="menu-list card">
    <view class="menu-item" bindtap="goToBind">
      <text class="menu-icon">💕</text>
      <text class="menu-label">{{partnerInfo ? '我的对象' : '绑定对象'}}</text>
      <text class="menu-arrow">›</text>
    </view>
    <view class="menu-item" bindtap="goToReminders">
      <text class="menu-icon">⏰</text>
      <text class="menu-label">提醒管理</text>
      <text class="menu-arrow">›</text>
    </view>
    <view class="menu-item" bindtap="goToNotifySettings">
      <text class="menu-icon">🔔</text>
      <text class="menu-label">通知设置</text>
      <text class="menu-arrow">›</text>
    </view>
    <view class="menu-item" bindtap="goToSettings">
      <text class="menu-icon">⚙️</text>
      <text class="menu-label">设置</text>
      <text class="menu-arrow">›</text>
    </view>
  </view>

  <view class="logout-btn" bindtap="logout">退出登录</view>
</view>