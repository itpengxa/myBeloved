.user-card {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 32rpx;
}

.user-info {
  display: flex;
  align-items: center;
}

.user-avatar {
  width: 120rpx;
  height: 120rpx;
  border-radius: 50%;
  margin-right: 24rpx;
  border: 4rpx solid var(--primary-light);
}

.user-meta {
  display: flex;
  flex-direction: column;
}

.user-name {
  font-size: 36rpx;
  font-weight: 600;
  color: var(--text);
}

.user-stats {
  font-size: 26rpx;
  color: var(--text-secondary);
  margin-top: 8rpx;
}

.user-stats .divider {
  margin: 0 16rpx;
  color: var(--border);
}

.edit-profile {
  font-size: 26rpx;
  color: var(--primary);
}

.menu-list {
  padding: 0;
  overflow: hidden;
  margin-top: 24rpx;
}

.menu-item {
  display: flex;
  align-items: center;
  padding: 32rpx;
  border-bottom: 2rpx solid var(--border);
}

.menu-item:last-child {
  border-bottom: none;
}

.menu-icon {
  font-size: 36rpx;
  margin-right: 24rpx;
}

.menu-label {
  flex: 1;
  font-size: 30rpx;
  color: var(--text);
}

.menu-arrow {
  font-size: 36rpx;
  color: var(--text-light);
}

.logout-btn {
  text-align: center;
  padding: 32rpx;
  margin-top: 48rpx;
  font-size: 30rpx;
  color: var(--error);
}