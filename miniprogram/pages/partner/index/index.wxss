.partner-card {
  text-align: center;
  padding: 48rpx;
}

.partner-avatar-wrap {
  position: relative;
  display: inline-block;
  margin-bottom: 24rpx;
}

.partner-avatar {
  width: 160rpx;
  height: 160rpx;
  border-radius: 50%;
  border: 6rpx solid var(--primary-light);
}

.heart-icon {
  position: absolute;
  bottom: 0;
  right: 0;
  font-size: 40rpx;
  background: #fff;
  border-radius: 50%;
  width: 56rpx;
  height: 56rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

.partner-name {
  font-size: 40rpx;
  font-weight: 600;
  color: var(--text);
}

.partner-days {
  font-size: 32rpx;
  color: var(--primary);
  margin-top: 12rpx;
  font-weight: 500;
}

.partner-date {
  font-size: 24rpx;
  color: var(--text-light);
  margin-top: 8rpx;
}

.empty-card {
  text-align: center;
  padding: 80rpx 48rpx;
}

.empty-icon {
  font-size: 80rpx;
  margin-bottom: 24rpx;
}

.empty-text {
  font-size: 30rpx;
  color: var(--text-secondary);
  margin-bottom: 32rpx;
}

.action-list {
  padding: 0;
  overflow: hidden;
}

.action-item {
  display: flex;
  align-items: center;
  padding: 32rpx;
  border-bottom: 2rpx solid var(--border);
}

.action-item:last-child {
  border-bottom: none;
}

.action-item.danger .action-label {
  color: var(--error);
}

.action-icon {
  font-size: 36rpx;
  margin-right: 24rpx;
}

.action-label {
  flex: 1;
  font-size: 30rpx;
  color: var(--text);
}

.action-arrow {
  font-size: 36rpx;
  color: var(--text-light);
}