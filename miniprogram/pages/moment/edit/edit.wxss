.content-input {
  width: 100%;
  min-height: 240rpx;
  font-size: 30rpx;
  line-height: 1.6;
  color: var(--text);
}

.char-count {
  text-align: right;
  font-size: 24rpx;
  color: var(--text-light);
  margin-top: 8rpx;
}

.image-section-title {
  font-size: 28rpx;
  font-weight: 500;
  margin-bottom: 16rpx;
}

.image-grid {
  display: flex;
  flex-wrap: wrap;
  gap: 16rpx;
}

.image-item {
  position: relative;
  width: 200rpx;
  height: 200rpx;
}

.preview-image {
  width: 100%;
  height: 100%;
  border-radius: var(--radius);
}

.image-remove {
  position: absolute;
  top: -12rpx;
  right: -12rpx;
  width: 40rpx;
  height: 40rpx;
  background: rgba(0,0,0,0.5);
  color: #fff;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 28rpx;
}

.image-add {
  width: 200rpx;
  height: 200rpx;
  border: 2rpx dashed var(--border);
  border-radius: var(--radius);
  display: flex;
  align-items: center;
  justify-content: center;
}

.add-icon {
  font-size: 64rpx;
  color: var(--text-light);
}

.setting-card {
  padding: 0;
  overflow: hidden;
}

.setting-item {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 28rpx 32rpx;
  border-bottom: 2rpx solid var(--border);
}

.setting-item:last-child {
  border-bottom: none;
}

.setting-label {
  font-size: 28rpx;
  color: var(--text);
}

.setting-value {
  font-size: 26rpx;
  color: var(--text-light);
  max-width: 400rpx;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
  text-align: right;
}

.mood-options {
  display: flex;
  gap: 12rpx;
}

.mood-item {
  padding: 8rpx 20rpx;
  border-radius: 8rpx;
  font-size: 26rpx;
  background: var(--bg);
  color: var(--text-secondary);
}

.mood-item.active {
  background: var(--primary-light);
  color: var(--primary);
}

.privacy-options {
  display: flex;
  gap: 16rpx;
}

.privacy-item {
  padding: 8rpx 24rpx;
  border-radius: 8rpx;
  font-size: 26rpx;
  background: var(--bg);
  color: var(--text-secondary);
}

.privacy-item.active {
  background: var(--primary-light);
  color: var(--primary);
}
