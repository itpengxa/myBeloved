.header-card {
  background: linear-gradient(135deg, var(--primary), var(--primary-dark));
  color: #fff;
}

.user-info {
  display: flex;
  align-items: center;
}

.avatar {
  width: 96rpx;
  height: 96rpx;
  border-radius: 50%;
  border: 4rpx solid rgba(255,255,255,0.3);
  margin-right: 24rpx;
}

.user-meta {
  display: flex;
  flex-direction: column;
}

.nickname {
  font-size: 36rpx;
  font-weight: 600;
}

.welcome {
  font-size: 24rpx;
  opacity: 0.85;
  margin-top: 4rpx;
}

.love-days {
  text-align: center;
  margin-top: 24rpx;
  padding-top: 24rpx;
  border-top: 2rpx solid rgba(255,255,255,0.2);
}

.days-number {
  font-size: 72rpx;
  font-weight: 700;
  line-height: 1;
}

.days-label {
  font-size: 26rpx;
  opacity: 0.9;
  margin-top: 8rpx;
}

.bind-tips {
  display: flex;
  align-items: center;
  justify-content: center;
  margin-top: 24rpx;
  padding-top: 24rpx;
  border-top: 2rpx solid rgba(255,255,255,0.2);
  font-size: 28rpx;
  opacity: 0.9;
}

.arrow {
  margin-left: 8rpx;
}

.letter-card {
  background: linear-gradient(135deg, #fff5f7, #ffffff);
  border: 2rpx solid var(--primary-light);
}

.letter-header {
  display: flex;
  align-items: center;
  margin-bottom: 16rpx;
}

.letter-icon {
  font-size: 40rpx;
  margin-right: 12rpx;
}

.letter-title {
  font-size: 32rpx;
  font-weight: 600;
  color: var(--primary);
}

.letter-preview {
  font-size: 28rpx;
  color: var(--text-secondary);
  line-height: 1.8;
  display: -webkit-box;
  -webkit-line-clamp: 3;
  -webkit-box-orient: vertical;
  overflow: hidden;
}

.letter-action {
  margin-top: 16rpx;
  font-size: 26rpx;
  color: var(--primary);
  text-align: right;
}

.quick-actions {
  display: flex;
  justify-content: space-around;
  margin-bottom: 24rpx;
}

.action-item {
  display: flex;
  flex-direction: column;
  align-items: center;
  background: var(--card-bg);
  border-radius: var(--radius-lg);
  padding: 32rpx 0;
  width: 30%;
  box-shadow: var(--shadow);
}

.action-icon {
  font-size: 48rpx;
  margin-bottom: 12rpx;
}

.action-item text {
  font-size: 26rpx;
  color: var(--text);
}

.section-title {
  font-size: 32rpx;
  font-weight: 600;
  margin-bottom: 16rpx;
  color: var(--text);
}

.moment-card {
  padding: 24rpx;
}

.moment-images {
  margin-bottom: 16rpx;
}

.moment-image {
  width: 100%;
  height: 360rpx;
  border-radius: var(--radius);
}

.moment-content {
  font-size: 28rpx;
  color: var(--text);
  line-height: 1.6;
  display: -webkit-box;
  -webkit-line-clamp: 2;
  -webkit-box-orient: vertical;
  overflow: hidden;
}

.moment-meta {
  display: flex;
  justify-content: space-between;
  margin-top: 16rpx;
  font-size: 24rpx;
  color: var(--text-light);
}
