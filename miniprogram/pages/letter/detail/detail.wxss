.letter-card {
  padding: 48rpx;
  background: linear-gradient(180deg, #fff5f7 0%, #ffffff 100%);
  border: 2rpx solid var(--primary-light);
}

.letter-header {
  text-align: center;
  margin-bottom: 40rpx;
  padding-bottom: 32rpx;
  border-bottom: 2rpx solid var(--primary-light);
}

.letter-title {
  font-size: 40rpx;
  font-weight: 600;
  color: var(--primary);
}

.letter-subtitle {
  font-size: 24rpx;
  color: var(--text-light);
  margin-top: 12rpx;
}

.letter-body {
  font-size: 32rpx;
  line-height: 2;
  color: var(--text);
  white-space: pre-wrap;
}

.recommend-card {
  margin-top: 24rpx;
}

.rec-section {
  margin-bottom: 32rpx;
  padding-bottom: 32rpx;
  border-bottom: 2rpx solid var(--border);
}

.rec-section:last-child {
  margin-bottom: 0;
  padding-bottom: 0;
  border-bottom: none;
}

.rec-title {
  font-size: 30rpx;
  font-weight: 600;
  color: var(--primary);
  margin-bottom: 16rpx;
}

.rec-name {
  font-size: 30rpx;
  font-weight: 500;
  color: var(--text);
}

.rec-place {
  font-size: 26rpx;
  color: var(--text-secondary);
  margin-top: 8rpx;
}

.rec-reason {
  font-size: 26rpx;
  color: var(--text-light);
  margin-top: 8rpx;
  line-height: 1.6;
}

.todo-item {
  display: flex;
  align-items: center;
  padding: 16rpx 0;
  font-size: 28rpx;
}

.todo-check {
  margin-right: 16rpx;
  font-size: 32rpx;
  color: var(--primary);
}